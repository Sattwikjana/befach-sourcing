# ─────────────────────────────────────────────────────────────────────
# Befach Store — environment variables
#
# For LOCAL development: copy this file to .env and fill in the secrets.
# For PRODUCTION (Render/Railway/etc.): set these in the dashboard, NOT
# in a committed file.
# ─────────────────────────────────────────────────────────────────────

# ── Required secrets ──
# Your CJDropshipping API key (from cjdropshipping.com → API)
CJ_API_KEY=

# Password for the /#/admin page (change from default before going live!)
ADMIN_PASSWORD=changeme

# ── Server ──
PORT=3001
NODE_ENV=production

# ── Pricing ──
# Markup percent on top of (CJ_wholesale + shipping)
PROFIT_MARKUP_PERCENT=20

# CJ adds an ~11% fee on top of API wholesale on their dropshipper page.
# Tune this if your CJ orders come in at a different markup.
CJ_FEE_FACTOR=1.11

# CJ's /freightCalculate API undercounts real shipping by ~10–13%. This
# multiplier corrects the quoted number before it feeds into pricing so
# we don't sell at a loss. Audit it against actual CJ invoices and tune.
SHIPPING_FEE_FACTOR=1.13

# Flat fallback shipping cost (USD) when CJ doesn't quote our methods
FALLBACK_SHIPPING_USD=3.49

# ── Currency / display ──
USD_TO_INR=85
STORE_CURRENCY=INR
STORE_NAME=Befach

# ── Shipping defaults ──
DEFAULT_SHIP_FROM=CN
DEFAULT_SHIP_TO=IN
SHIPPING_METHOD=CJPacket Asia Ordinary

# ── AI search (OpenRouter → Gemini 2.0 Flash) ──
# Get a key at https://openrouter.ai/keys. Without it, search still works
# but loses the natural-language understanding (Hindi/Hinglish, typo
# tolerance, "blue dress under 2000" filter extraction, etc.).
OPENROUTER_API_KEY=
# Hard cap on AI spend per day in USD. Hit the cap → search falls back to
# plain CJ keyword matching for the rest of the day.
OPENROUTER_DAILY_CAP_USD=1.0

# ── CJ payment mode (how customer orders get paid to CJ) ──
# 1 = manual: CJ returns a cjPayUrl, you click & pay each order
# 2 = auto:   CJ deducts from your prefunded CJ wallet balance ← default
# 3 = create only, pay separately later
# Keep ~$200–500 in the CJ wallet (cjdropshipping.com → My CJ → Wallet)
# so auto-pay doesn't fail mid-order. Use cj.getBalance() to check.
CJ_PAY_TYPE=2
