# ─────────────────────────────────────────────────────────────────────
# Befach Store — environment variables
#
# For LOCAL development: copy this file to .env and fill in the secrets.
# For PRODUCTION (Render/Railway/etc.): set these in the dashboard, NOT
# in a committed file.
# ─────────────────────────────────────────────────────────────────────

# ── Required secrets ──
# Your CJDropshipping API key (from cjdropshipping.com → API)
CJ_API_KEY=

# Password for the /#/admin page (change from default before going live!)
ADMIN_PASSWORD=changeme

# ── Server ──
PORT=3001
NODE_ENV=production

# ── Pricing ──
# Markup percent on top of (CJ_wholesale + shipping)
PROFIT_MARKUP_PERCENT=20

# CJ adds an ~11% fee on top of API wholesale on their dropshipper page.
# Tune this if your CJ orders come in at a different markup.
CJ_FEE_FACTOR=1.11

# Flat fallback shipping cost (USD) when CJ doesn't quote our methods
FALLBACK_SHIPPING_USD=3.49

# ── Currency / display ──
USD_TO_INR=85
STORE_CURRENCY=INR
STORE_NAME=Befach

# ── Shipping defaults ──
DEFAULT_SHIP_FROM=CN
DEFAULT_SHIP_TO=IN
SHIPPING_METHOD=CJPacket Asia Ordinary
